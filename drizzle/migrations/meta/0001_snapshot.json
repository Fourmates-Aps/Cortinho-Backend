      "definition": "select \"cards\".\"id\", \"cards\".\"user_id\", \"cards\".\"name\", \"cards\".\"category\", \"cards\".\"status\", \"cards\".\"is_rookie\", \"cards\".\"is_autographed\", \"cards\".\"is_graded\", \"grading_companies\".\"abbr\", \"cards\".\"grade_value\", \"cards\".\"purchase_price\", \"cards\".\"current_value\", ROUND(\"cards\".\"current_value\" - \"cards\".\"purchase_price\", 2) as \"pl_abs\", \n        CASE WHEN \"cards\".\"purchase_price\" > 0\n          THEN ROUND(((\"cards\".\"current_value\" - \"cards\".\"purchase_price\") / \"cards\".\"purchase_price\") * 100, 2)\n          ELSE NULL\n        END as \"pl_pct\", \"cards\".\"created_at\" from \"cards\" left join \"grading_companies\" on \"grading_companies\".\"id\" = \"cards\".\"grade_company_id\" where \"cards\".\"deleted_at\" IS NULL",
