# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cortinho

# ── Clerk ─────────────────────────────────────────────────────
# Found in Clerk dashboard → API Keys
CLERK_INSTANCE=your-clerk-instance.clerk.accounts.dev

# Found in Clerk dashboard → Webhooks → signing secret
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated. iOS native apps don't need an entry here.
ALLOWED_ORIGINS=http://localhost:3000,https://cortinho.com

# ── Rate limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AI_RATE_LIMIT_MAX=10

# ── Redis (optional — uses in-process cache if not set) ───────
# REDIS_URL=redis://localhost:6379

# ── External pricing ──────────────────────────────────────────
# PRICECHARTING_TOKEN=your_token_here
